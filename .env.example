# Groq API キー（https://console.groq.com/keys で無料取得）
GROQ_API_KEY=gsk_paste_your_full_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# 記事生成の最大トークン（長文向け。省略時 8192）
# GROQ_MAX_TOKENS=8192

# サイト基本情報（SEO・OGP・sitemap・RSS・canonical）
SITE_NAME=TechMatome AI
SITE_URL=http://localhost:3000
SITE_DESCRIPTION=AIが生成する技術まとめブログ。Linux・Git・Docker・Pythonなど初心者向けに解説。

# 本番デプロイ時
# NODE_ENV=production
# SITE_URL=https://your-domain.com
# PORT=3000

PORT=3000
