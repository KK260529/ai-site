# Groq API キー（https://console.groq.com/keys で無料取得）
GROQ_API_KEY=gsk_paste_your_full_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# 記事生成の最大トークン（長文向け。省略時 8192）
# GROQ_MAX_TOKENS=8192

# サイト基本情報（SEO・OGP・sitemap・RSS・canonical）
SITE_NAME=StackShelf
SITE_TAGLINE=技術を、ひとつずつ積み上げる。
SITE_URL=http://localhost:3000
SITE_DESCRIPTION=StackShelf — Linux・Git・Docker・Python など、初心者にもわかる技術まとめ。AI編集と構造化メモリで組み立てた学習サイト。

# 本番デプロイ時（必須）
# NODE_ENV=production
# SITE_URL=https://your-domain.com
# ADMIN_USER=admin
# ADMIN_PASSWORD=12文字以上の強いパスワード

# PORT=3000

PORT=3000
