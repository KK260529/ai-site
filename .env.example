# Groq API キー（https://console.groq.com/keys で無料取得）
GROQ_API_KEY=gsk_paste_your_full_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# 記事生成の最大トークン（長文向け。省略時 8192）
# GROQ_MAX_TOKENS=4096

# 記事の文章量プリセット（short | medium | long）。管理画面の初期選択にも使われます
# ARTICLE_LENGTH=medium
# 上書き（上級者向け）: ARTICLE_MIN_CHARS / ARTICLE_TARGET_MIN / ARTICLE_TARGET_MAX

# サイト基本情報（SEO・OGP・sitemap・RSS・canonical）
SITE_NAME=StackShelf
SITE_TAGLINE=エラーメッセージを検索して、すぐ解決策を見つける。
SITE_URL=http://localhost:3000
SITE_DESCRIPTION=StackShelf — Python・Git・Docker・Linux の技術エラー5,000件超を検索。ModuleNotFoundError や push rejected など、実際のエラー全文でヒットする解説サイト。
# 検索結果・SNS向け（省略時は下記デフォルト）
# HOME_PAGE_TITLE=技術エラー検索 | StackShelf — Python・Git・Docker エラー解決
# HOME_HERO_TITLE=技術エラー検索サイト
# SITE_OG_IMAGE=https://your-domain.com/og-default.svg
# SITE_LOGO=https://your-domain.com/favicon.svg
# TWITTER_HANDLE=your_handle
# Google Analytics 4（省略時は計測タグなし）
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Search Console（HTMLタグ方式。TXTの値の「=」以降だけでも可）
# GOOGLE_SITE_VERIFICATION=466l6Z_ld1yTdI-ezGW3ci89ftupoqmasyOThXBmTfE

# 本番デプロイ時（必須）
# NODE_ENV=production
# SITE_URL=https://your-domain.com
# ADMIN_USER=admin
# ADMIN_PASSWORD=12文字以上の強いパスワード
# CONTACT_EMAIL=your@email.com
# PORT=3000

# 記事公開後に Git push → Vercel 自動デプロイ（無効: AUTO_GIT_DEPLOY=false）
# AUTO_GIT_DEPLOY=true

# 広告（Google AdSense / 忍者AdMax など）
AD_CLIENT=ca-pub-1246463987388134
# AD_SLOT_TOP=1234567890
# AD_SLOT_BOTTOM=1234567891
# AD_SLOT_INLINE=1234567892
# 忍者AdMax タグ（HTML をそのまま1行で）
# AD_HTML_TOP=<!-- admax --><script src="https://adm.shinobi.jp/s/xxxxxxxx"></script><!-- admax -->
# AD_HTML_INLINE=...
# AD_HTML_BOTTOM=...
# 広告密度（省略時: 本文内4 / ホーム3件ごと / エピソード5件ごと）
# AD_MAX_INLINE=4
# AD_HOME_INTERVAL=3
# AD_EPISODE_INTERVAL=5
# 共通タグ1本だけの場合（top にのみ使用。AD_HTML_TOP より優先度低）
# AD_HTML=...
# 任意の head タグ
# AD_HEAD_HTML=<script>...</script>

PORT=3000
